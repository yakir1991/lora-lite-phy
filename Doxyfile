# Doxyfile — lora-lite-phy API documentation
# Generate with:  doxygen Doxyfile
# Output:         docs/api/html/index.html

PROJECT_NAME           = "lora-lite-phy"
PROJECT_BRIEF          = "Standalone LoRa PHY-layer encoder/decoder in C++20"
PROJECT_NUMBER         = 0.2.0

OUTPUT_DIRECTORY       = docs/api
INPUT                  = host_sim/include/host_sim \
                         host_sim/src
FILE_PATTERNS          = *.hpp *.h *.cpp
RECURSIVE              = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_MAN           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

# Exclude test code and vendored libraries
EXCLUDE                = host_sim/tests \
                         host_sim/third_party

SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md
